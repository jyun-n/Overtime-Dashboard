# PostgreSQL — 로컬 개발 기본값. 실제 비밀번호로 교체 필요.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/overtime_dashboard?schema=public"

# 서버
PORT=4001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=8h

# 업로드 (파일은 메모리에서 파싱, 디스크 저장 안 함)
MAX_UPLOAD_SIZE_MB=20

# 마스터/탈퇴 비밀번호 — root admin 비밀번호 재설정 백도어로 사용.
# 반드시 강력한 랜덤 값으로 교체. 예) node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
WITHDRAW_PASSWORD=REPLACE_WITH_STRONG_SECRET

# 로그
LOG_LEVEL=info
LOG_DIR=./logs

# CORS — 프론트 origin
CORS_ORIGIN=http://localhost:5174

# trust proxy — 'loopback'(기본, 로컬 프록시만), 숫자(hop 수), CIDR, 또는 'true'/'false'.
# 리버스 프록시 한 단을 거치면 1, 두 단이면 2. 'true'는 X-Forwarded-For 위조에 취약하므로 사용 금지.
TRUST_PROXY=loopback

# IP 접근 제어(ACL) 적용 강도. 관리자 화면에서 등록한 허용 IP 목록에만 로그인을 허용한다.
#   off     — 미적용 (기본)
#   audit   — 차단하지 않고 위반만 로그로 기록 (enforce 켜기 전 실측/관찰용 — 권장 1단계)
#   enforce — 등록된 IP가 아니면 로그인/요청 차단
# 주의: 정확한 클라이언트 IP 식별을 위해 TRUST_PROXY가 올바라야 함.
#       잠겼을 때는 이 값을 off로 바꾸고 재시작하면 풀린다(비상탈출).
IP_ACL_MODE=off
