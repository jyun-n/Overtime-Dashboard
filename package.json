{
  "name": "overtime-dashboard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:ngrok": "ngrok http 5174",
    "dev": "concurrently -k -n BE,FE -c yellow,cyan \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:demo": "concurrently -k -n BE,FE,NGROK -c yellow,cyan,magenta \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:ngrok\"",
    "build": "npm --workspace backend run build && npm --workspace frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
